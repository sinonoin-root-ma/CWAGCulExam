.index-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

/* 圆形 LOGO 容器（关键修改） */
.logo-container {
  margin-bottom: 100rpx;/* 将LOGO和标题区域整体上移，减少顶部的留白。 */
  margin-top: -140rpx; /* 强制元素向上移动 */
  width: 270rpx; /* 圆形直径 */
  height: 270rpx;
  border-radius: 50%; /* 圆形圆角 */
  overflow: hidden; /* 裁剪超出圆形的部分 */
  /*border: 4rpx solid #4263EB;  蓝色边框点缀 */
  box-shadow: 0 4rpx 16rpx rgba(247, 250, 250, 0.918); /* 轻微阴影提升质感 */
  display: flex;
  align-items: center;
  justify-content: center;
  /* background-color: #fff; 白色背景，避免 LOGO 透明时显示异常 */
  background-color:#fff; /* 浅绿色背景突出LOGO */
}

/* LOGO 图片适配圆形容器 */
.logo-img {
  width: 180rpx; /* 图片宽度小于容器，预留边框空间 */
  height: auto;
  object-fit: cover; /* 保持图片比例，填充容器 */
}

.system-name {
  text-align: center;
  margin-bottom: 160rpx; /* 标题区域与开始按钮之间的距离。 */
  padding-top: 10rpx;
}

.title {
  font-size: 45rpx;
  font-weight: 600;
  color: #42b983;
  display: block;
  margin-bottom: 30rpx;/* 已调大的标题与副标题间距 */
}

.subtitle {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.start-btn {
  width: 100%;
  background-color: #42b983;
  color: #fff;
  border-radius: 100rpx; /*四个角都应用相同的半径 左上角、右上角、右下角、左下角（顺时针顺序）*/  
  padding: 30rpx 0; /* 设置元素的内边距，即元素内容与其边框之间的空间 按上、右、下、左的顺时针方向分别设置,上下为30，左右为0*/
  text-align: center;
  font-size: 44rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(36, 185, 173, 0.4); /* 使按钮在悬停时产生“浮起”的立体效果 */
}

.start-btn:active {
  background-color: #42b983;
  transform: scale(0.98); /* 使元素在水平方向（X轴）和垂直方向（Y轴）上同时等比例缩小/放大 */
  box-shadow: 0 2rpx 8rpx rgba(36, 185, 173, 0.3);
}

.footer-hint {
  position: fixed;
  bottom: 140rpx;
  font-size: 26rpx;
  color: #666;
}